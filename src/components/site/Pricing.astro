---
/**
 * Pricing — auto-fit card grid with featured card
 */
import { getCollection } from "astro:content";

const plans = (await getCollection("pricing")).sort((a, b) => a.data.order - b.data.order);
---

<section id="pricing" class="container py-16">
  <header class="section-head">
    <p class="section-head__eyebrow" data-animate>Plans & pricing</p>
    <h2 class="section-head__title" data-animate>Simple pricing. Real outcomes.</h2>
    <p class="section-head__lead" data-animate>
      Start small, scale when you're ready. No lock-in, no surprises.
    </p>
  </header>

  <div class="pricing__grid">
    {plans.map((plan) => (
      <div class={`pricing__card ${plan.data.highlight ? "pricing__card--featured" : ""}`} data-animate>
        {plan.data.highlight && <span class="pricing__badge">Popular</span>}
        <div class="pricing__plan">{plan.data.name}</div>
        <div class="pricing__price-row">
          <span class="pricing__price">{plan.data.price}</span>
          {plan.data.per && <span class="pricing__per">{plan.data.per}</span>}
        </div>
        <p class="pricing__desc">{plan.data.description}</p>
        <ul class="pricing__features">
          {plan.data.features.map((feature) => (
            <li class="pricing__feature">
              <svg class="pricing__check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              {feature}
            </li>
          ))}
        </ul>
        <a href="#contact" class={`pricing__cta ${plan.data.highlight ? "pricing__cta--primary" : ""}`}>
          {plan.data.cta}
        </a>
      </div>
    ))}
  </div>
</section>

<style>
  .pricing__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
    gap: var(--spacing-6);
    align-items: start;
  }

  .pricing__card {
    position: relative;
    padding: clamp(1.5rem, 3vw, 2rem);
    border: 1px solid var(--border);
    border-radius: var(--radius-2xl);
    background: var(--card);
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .pricing__card--featured {
    border-color: var(--primary);
    box-shadow: var(--shadow-md);
  }

  .pricing__badge {
    position: absolute;
    top: -0.7rem;
    left: 50%;
    transform: translateX(-50%);
    padding: 0.2rem 0.7rem;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: var(--primary);
    color: var(--primary-foreground);
    border-radius: var(--radius-full);
  }

  .pricing__plan {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted-foreground);
  }

  .pricing__price-row {
    display: flex;
    align-items: baseline;
    gap: 0.375rem;
  }

  .pricing__price {
    font-size: clamp(1.8rem, 4vw, 2.4rem);
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .pricing__per {
    font-size: 0.875rem;
    color: var(--muted-foreground);
  }

  .pricing__desc {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--muted-foreground);
    margin: 0;
  }

  .pricing__features {
    margin: 0.5rem 0 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    font-size: 0.875rem;
  }

  .pricing__feature {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .pricing__check {
    width: 1.1rem;
    height: 1.1rem;
    flex-shrink: 0;
    margin-top: 0.15rem;
    color: var(--success);
  }

  .pricing__cta {
    display: block;
    margin-top: 0.5rem;
    padding: 0.7rem 1.2rem;
    text-align: center;
    font-weight: 600;
    font-size: 0.9375rem;
    text-decoration: none;
    color: var(--secondary-foreground);
    background: var(--secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    transition: box-shadow 0.2s ease;
  }

  .pricing__cta:hover {
    box-shadow: var(--shadow-md);
  }

  .pricing__cta--primary {
    background: var(--primary);
    color: var(--primary-foreground);
    border-color: var(--primary);
  }

  .pricing__cta:focus-visible {
    outline: 2px solid var(--ring);
    outline-offset: 2px;
  }
</style>
