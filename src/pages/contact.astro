---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../config/site.config";
---

<BaseLayout title="Contact" description="Get in touch with HQNepal. Book a strategy call or email us about your project — we respond within one business day." path="/contact">
  <section class="page-hero">
    <div class="bg-grid"></div>
    <div class="bg-glow"></div>
    <div class="container page-hero__inner">
      <p class="page-hero__eyebrow" data-animate>Get in touch</p>
      <h1 class="page-hero__title" data-animate>Let's build something together</h1>
      <p class="page-hero__text" data-animate>
        Tell us about your product, campaign or system. We'll come back within one business day with a plan — not a sales pitch.
      </p>
    </div>
  </section>

  <section class="container py-16">
    <div class="contact-grid">
      <div class="contact-card" data-animate>
        <h2 class="contact-card__title">Email us</h2>
        <p class="contact-card__text">
          For project inquiries, partnerships, or just to say hi — drop us a line.
        </p>
        <a href={`mailto:${siteConfig.email}`} class="contact-card__link">
          {siteConfig.email}
        </a>
      </div>

      <div class="contact-card" data-animate>
        <h2 class="contact-card__title">Book a call</h2>
        <p class="contact-card__text">
          Not an email person? Send us your availability and we'll find a 30-minute window that works.
        </p>
        <a href={`mailto:${siteConfig.email}?subject=Let's%20schedule%20a%20call`} class="contact-card__link">
          Schedule a call
        </a>
      </div>

      <div class="contact-card" data-animate>
        <h2 class="contact-card__title">Find us</h2>
        <p class="contact-card__text">
          Pokhara, Nepal — working remotely with clients across South Asia, the Gulf, Europe and North America.
        </p>
        <div class="contact-card__socials">
          {siteConfig.socialLinks.map((link) => (
            <a href={link.url} class="contact-card__social" aria-label={link.label} target="_blank" rel="noopener noreferrer">
              {link.platform === "github" && (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.161 22 16.418 22 12c0-5.523-4.477-10-10-10z"/></svg>
              )}
              {link.platform === "linkedin" && (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              )}
              {link.platform === "x" && (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              )}
              {link.platform === "discord" && (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 00.0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 00-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 01-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 01.0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 01.0785.0095c.1202.099.246.1981.3728.2924a.077.077 0 01-.0066.1276 12.2986 12.2986 0 01-1.873.8914.0766.0766 0 00-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 00.0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 00.0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 00-.0312-.0286zM8.02 15.3312c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9555-2.4189 2.157-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.9555 2.4189-2.1569 2.4189zm7.9748 0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.4189-2.1568 2.4189z"/></svg>
              )}
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="container py-16">
    <header class="section-head">
      <p class="section-head__eyebrow" data-animate>What to expect</p>
      <h2 class="section-head__title" data-animate>Our process</h2>
    </header>

    <div class="process-steps">
      <div class="process-step" data-animate>
        <span class="process-step__num">01</span>
        <div>
          <h3 class="process-step__title">You reach out</h3>
          <p class="process-step__text">
            Email or call with a brief description of what you need. No NDAs required just to talk.
          </p>
        </div>
      </div>
      <div class="process-step" data-animate>
        <span class="process-step__num">02</span>
        <div>
          <h3 class="process-step__title">We scope it</h3>
          <p class="process-step__text">
            A 30-minute discovery call, then a written proposal with timeline, deliverables and pricing. No surprises.
          </p>
        </div>
      </div>
      <div class="process-step" data-animate>
        <span class="process-step__num">03</span>
        <div>
          <h3 class="process-step__title">We ship it</h3>
          <p class="process-step__text">
            Work starts within a week. Weekly demos, transparent progress, and a team that actually responds to Slack.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    position: relative;
    overflow: hidden;
    padding: clamp(3.5rem, 8vw, 6.5rem) 0;
  }

  .page-hero__inner {
    position: relative;
    z-index: 1;
  }

  .page-hero__eyebrow {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--muted-foreground);
    margin-bottom: 1rem;
  }

  .page-hero__title {
    font-size: clamp(2.25rem, 4vw, 3.5rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
    max-width: 28ch;
    margin: 0;
  }

  .page-hero__text {
    margin-top: 1.25rem;
    font-size: clamp(0.95rem, 1.2vw, 1.125rem);
    line-height: 1.6;
    color: var(--muted-foreground);
    max-width: 40rem;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
    gap: var(--spacing-6);
  }

  .contact-card {
    padding: clamp(1.5rem, 3vw, 2rem);
    border: 1px solid var(--border);
    border-radius: var(--radius-2xl);
    background: var(--card);
    box-shadow: var(--shadow-sm);
  }

  .contact-card__title {
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0;
  }

  .contact-card__text {
    margin-top: 0.75rem;
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--muted-foreground);
  }

  .contact-card__link {
    display: inline-block;
    margin-top: 1.25rem;
    padding: 0.6rem 1.2rem;
    background: var(--primary);
    color: var(--primary-foreground);
    font-weight: 600;
    font-size: 0.875rem;
    text-decoration: none;
    border-radius: var(--radius-lg);
    transition: box-shadow 0.2s ease;
  }

  .contact-card__link:hover { box-shadow: var(--shadow-md); }

  .contact-card__socials {
    margin-top: 1.25rem;
    display: flex;
    gap: 0.5rem;
  }

  .contact-card__social {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    color: var(--muted-foreground);
    text-decoration: none;
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .contact-card__social:hover {
    color: var(--foreground);
    border-color: var(--foreground);
  }

  .process-steps {
    max-width: 42rem;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .process-step {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
  }

  .process-step__num {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--muted-foreground);
    flex-shrink: 0;
    padding-top: 0.15rem;
  }

  .process-step__title {
    font-size: 1.0625rem;
    font-weight: 700;
    margin: 0;
  }

  .process-step__text {
    margin-top: 0.375rem;
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--muted-foreground);
  }
</style>
